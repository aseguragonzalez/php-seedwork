{
  "authors": [
    {
      "email": "a.segura.gonzalez@gmail.com",
      "name": "Alfonso Segura"
    }
  ],
  "autoload": {
    "psr-4": {
      "SeedWork\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Examples\\": "docs/examples/",
      "Tests\\": "tests/"
    }
  },
  "config": {
    "platform": {
      "php": "8.4"
    }
  },
  "description": "DDD and Hexagonal (Clean) Architecture building blocks (aggregates, entities, value objects, etc).",
  "license": "MIT",
  "name": "aseguragonzalez/php-seedwork",
  "require": {
    "php": "^8.4"
  },
  "require-dev": {
    "friendsofphp/php-cs-fixer": "^3.95.2",
    "phpstan/phpstan": "^2.1",
    "phpunit/phpunit": "^12.5"
  },
  "scripts": {
    "check": [
      "@cs",
      "@stan",
      "@test:no-coverage"
    ],
    "cs": "php-cs-fixer fix --dry-run --diff",
    "cs:fix": "php-cs-fixer fix",
    "stan": "phpstan analyse --memory-limit=1G",
    "test": "phpunit --testsuite default --coverage-html coverage/html",
    "test:examples": "phpunit --testsuite examples --no-coverage",
    "test:no-coverage": "phpunit --testsuite default --no-coverage"
  },
  "support": {
    "docs": "https://github.com/aseguragonzalez/php-seedwork/tree/main/docs",
    "source": "https://github.com/aseguragonzalez/php-seedwork.git"
  },
  "type": "library"
}
