{
  "containerEnv": {
    "XDEBUG_MODE": "coverage,debug,develop"
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "bmewburn.vscode-intelephense-client",
        "DavidAnson.vscode-markdownlint",
        "dbaeumer.vscode-eslint",
        "donjayamanne.githistory",
        "MehediDracula.php-namespace-resolver",
        "mhutchie.git-graph",
        "recca0120.vscode-phpunit",
        "xdebug.php-debug",
        "wongjn.php-sniffer"
      ],
      "settings": {
        "terminal.integrated.defaultProfile.linux": "zsh"
      }
    }
  },
  "dockerComposeFile": "docker-compose.yml",
  "features": {
    "ghcr.io/devcontainers/features/git:1": {},
    "ghcr.io/gvatsal60/dev-container-features/pre-commit:1": {}
  },
  "forwardPorts": [
    8001,
    9003
  ],
  "mounts": [
    "source=php-seedwork-pre-commit-cache,target=/home/vscode/.cache/pre-commit,type=volume"
  ],
  "name": "PHP SeedWork",
  "service": "app",
  "workspaceFolder": "/workspaces/php-seedwork",
  "portsAttributes": {
    "8001": {
      "label": "MkDocs",
      "onAutoForward": "openBrowser"
    },
    "9003": {
      "label": "Xdebug",
      "onAutoForward": "notify"
    }
  },
  "postCreateCommand": "bash /workspaces/php-seedwork/.devcontainer/setup.sh",
  "remoteUser": "vscode"
}
